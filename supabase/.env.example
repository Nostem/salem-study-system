# Supabase/Postgres import settings for local CLI use.
# Copy to ../.env or export in your shell. Do not commit real values.

# Use the pooled or direct Postgres connection string from Supabase Project Settings > Database.
# Example shape only; replace host/project/password before use:
SUPABASE_DB_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
