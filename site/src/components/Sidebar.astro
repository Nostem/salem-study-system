---
// TODO Phase 3: mastery dots — requires progress data source
import { getCollection } from 'astro:content';

interface Props {
  currentSlug?: string;
  sidebarId?: string;
  sidebarVariant?: 'desktop' | 'mobile';
}

const { currentSlug, sidebarId, sidebarVariant = 'desktop' } = Astro.props;

const articles = await getCollection('wiki');

// Group articles by category (top-level directory)
const categories: Record<string, { title: string; slug: string; status: string; depth: number }[]> = {};
const categoryOrder = ['systems', 'tech-specs', 'exams', 'eops', 'concepts', 'admin', 'abnormals', 'procedures'];
const categoryLabels: Record<string, string> = {
  systems: 'Systems',
  'tech-specs': 'Tech Specs',
  exams: 'Exams',
  eops: 'EOPs',
  concepts: 'Concepts',
  admin: 'Admin Procedures',
  abnormals: 'Abnormals',
  procedures: 'Procedures',
};

// Categories where individual sub-directory items should be hidden from sidebar
// (they're embedded in parent articles or accessed via parent links)
const hideSubItems = new Set(['exams']);

for (const article of articles) {
  const slug = article.id;
  if (slug === '_index') continue;

  const parts = slug.split('/');
  const category = parts[0] ?? 'uncategorized';
  const depth = parts.length - 1; // 0 = top-level in category, 1 = one folder deep, etc.
  const title = article.data.title ?? parts[parts.length - 1]?.replace(/-/g, ' ') ?? slug;
  const status = article.data.status ?? 'draft';

  // Skip sub-directory items for categories in hideSubItems
  // e.g., exams/2023/q01-... has depth 2, skip it. exams/2023-written-exam has depth 1, keep it.
  if (hideSubItems.has(category) && depth > 1) continue;

  if (!categories[category]) categories[category] = [];
  categories[category].push({ title, slug, status, depth });
}

// Natural numeric sort — handles "TS 3/4.1" before "TS 3/4.10", "Q1" before "Q10"
function naturalSort(a: string, b: string): number {
  const re = /(\d+)|(\D+)/g;
  const aParts = a.match(re) || [];
  const bParts = b.match(re) || [];

  for (let i = 0; i < Math.max(aParts.length, bParts.length); i++) {
    const aPart = aParts[i] ?? '';
    const bPart = bParts[i] ?? '';

    const aNum = parseInt(aPart, 10);
    const bNum = parseInt(bPart, 10);

    if (!isNaN(aNum) && !isNaN(bNum)) {
      if (aNum !== bNum) return aNum - bNum;
    } else {
      const cmp = aPart.localeCompare(bPart);
      if (cmp !== 0) return cmp;
    }
  }
  return 0;
}

// Sort articles within each category using natural sort
for (const cat of Object.keys(categories)) {
  categories[cat].sort((a, b) => naturalSort(a.title, b.title));
}

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<aside id={sidebarId} data-sidebar-variant={sidebarVariant} class="sidebar w-[240px] min-w-[240px] border-r border-[#1a2035] bg-[#0b1020] geo-pattern text-xs overflow-y-auto h-[calc(100vh-48px)] sticky top-[48px]">
  <nav class="py-4">
    {categoryOrder.map((cat) => {
      const items = categories[cat];
      if (!items || items.length === 0) return null;
      const hasActive = items.some((item) => currentSlug === item.slug);
      return (
        <div class="mb-1 sidebar-category" data-category={cat} data-has-active={hasActive ? 'true' : 'false'}>
          <button
            type="button"
            class="w-full flex items-center justify-between px-4 py-1.5 text-[#2a6f97] font-mono font-semibold tracking-[0.18em] text-[10px] uppercase hover:text-[#60a5fa] transition-colors cursor-pointer bg-transparent border-none"
            data-sidebar-toggle={cat}
          >
            <span>{categoryLabels[cat] ?? cat}</span>
            <span class="sidebar-chevron text-[8px] transition-transform" data-chevron={cat}>&#9662;</span>
          </button>
          <div class="sidebar-items" data-items={cat}>
            {items.map((item) => {
              const isActive = currentSlug === item.slug;
              return (
                <a
                  href={`${base}${item.slug}`}
                  class:list={[
                    'block px-4 pl-6 py-[5px] no-underline transition-colors',
                    isActive
                      ? 'bg-[#111d35] text-[#60a5fa] border-l-2 border-[#2a6f97]'
                      : 'text-[#8b95a5] hover:text-[#c8cdd5] hover:bg-[#0d1525]',
                  ]}
                >
                  {item.title}
                </a>
              );
            })}
          </div>
        </div>
      );
    })}
    <div class="mt-4 px-4 pt-2 border-t border-[#1a2035]">
      <a href={`${base}graph`} class="flex items-center gap-1.5 px-3 py-1.5 text-[#6b7280] hover:text-[#c8cdd5] no-underline text-[11px]">
        <span class="text-sm">◉</span> Graph View
      </a>
    </div>
  </nav>
</aside>

<script>
  const STORAGE_KEY = 'sidebar-collapsed';

  function getCollapsed(): Set<string> {
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      return stored ? new Set(JSON.parse(stored)) : new Set();
    } catch {
      return new Set();
    }
  }

  function saveCollapsed(collapsed: Set<string>) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify([...collapsed]));
  }

  function initSidebar() {
    const collapsed = getCollapsed();
    const categories = document.querySelectorAll<HTMLElement>('.sidebar-category');

    categories.forEach((cat) => {
      const name = cat.dataset.category!;
      const hasActive = cat.dataset.hasActive === 'true';
      const items = cat.querySelector<HTMLElement>(`[data-items="${name}"]`);
      const chevron = cat.querySelector<HTMLElement>(`[data-chevron="${name}"]`);
      const btn = cat.querySelector<HTMLElement>(`[data-sidebar-toggle="${name}"]`);

      if (!items || !chevron || !btn) return;

      // If this category has the active page, expand it regardless
      const isCollapsed = hasActive ? false : collapsed.has(name);

      if (isCollapsed) {
        items.style.display = 'none';
        chevron.style.transform = 'rotate(-90deg)';
      }

      btn.addEventListener('click', () => {
        const hidden = items.style.display === 'none';
        items.style.display = hidden ? '' : 'none';
        chevron.style.transform = hidden ? '' : 'rotate(-90deg)';

        if (hidden) {
          collapsed.delete(name);
        } else {
          collapsed.add(name);
        }
        saveCollapsed(collapsed);
      });
    });
  }

  // Run on initial load and on Astro page transitions
  initSidebar();
  document.addEventListener('astro:after-swap', initSidebar);
</script>
