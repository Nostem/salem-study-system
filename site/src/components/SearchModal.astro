---
// Pagefind search modal — initialized client-side
const base = import.meta.env.BASE_URL;
---

<div id="search-modal" class="fixed inset-0 z-50 hidden">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/60" onclick="closeSearch()"></div>

  <!-- Modal -->
  <div class="relative mx-auto mt-[15vh] w-full max-w-lg bg-[#0d1220] border border-[#1a2035] rounded-lg shadow-2xl overflow-hidden">
    <div class="p-4">
      <input
        id="search-input"
        type="text"
        placeholder="Search articles..."
        class="w-full bg-[#111827] border border-[#1a2035] rounded-md px-4 py-2.5 text-sm text-[#e0e4ea] placeholder-[#6b7280] outline-none focus:border-[#2a6f97]"
        autocomplete="off"
      />
    </div>
    <div id="search-results" class="max-h-[50vh] overflow-y-auto px-4 pb-4">
      <!-- Results populated by Pagefind -->
    </div>
  </div>
</div>

<script is:inline define:vars={{ base }}>
  const normalizedBase = base.endsWith('/') ? base : `${base}/`;
  const pagefindModulePath = `${normalizedBase}pagefind/pagefind.js`;

  function getSearchElements() {
    return {
      modal: document.getElementById('search-modal'),
      input: document.getElementById('search-input'),
      results: document.getElementById('search-results'),
    };
  }

  function openSearch() {
    const { modal, input } = getSearchElements();
    if (!modal || !input) return;

    modal.classList.remove('hidden');
    input.focus();
  }

  function closeSearch() {
    const { modal, input, results } = getSearchElements();
    if (!modal || !input || !results) return;

    modal.classList.add('hidden');
    input.value = '';
    results.innerHTML = '';
  }

  function bindSearchTriggers() {
    document.querySelectorAll('#search-trigger, #search-trigger-mobile').forEach((trigger) => {
      if (trigger.dataset.searchBound === 'true') return;
      trigger.dataset.searchBound = 'true';
      trigger.addEventListener('click', openSearch);
    });
  }

  // Keyboard shortcut: Cmd+K / Ctrl+K
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      const { modal } = getSearchElements();
      if (!modal) return;

      if (modal.classList.contains('hidden')) {
        openSearch();
      } else {
        closeSearch();
      }
    }
    if (e.key === 'Escape') closeSearch();
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindSearchTriggers, { once: true });
  } else {
    bindSearchTriggers();
  }
  document.addEventListener('astro:page-load', bindSearchTriggers);

  function attachInputHandlers(pagefind) {
    const { input, results } = getSearchElements();
    if (!input || !results || input.dataset.pagefindBound === 'true') return;

    input.dataset.pagefindBound = 'true';

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const firstLink = document.querySelector('#search-results a');
        if (firstLink) window.location.href = firstLink.href;
      }

      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        e.preventDefault();
        const links = [...document.querySelectorAll('#search-results a')];
        if (!links.length) return;
        const active = document.querySelector('#search-results a.search-active');
        let idx = active ? links.indexOf(active) : -1;
        if (active) active.classList.remove('search-active', 'bg-[#111827]');
        idx = e.key === 'ArrowDown' ? Math.min(idx + 1, links.length - 1) : Math.max(idx - 1, 0);
        links[idx].classList.add('search-active', 'bg-[#111827]');
        links[idx].scrollIntoView({ block: 'nearest' });
      }
    });

    let debounceTimer;
    input.addEventListener('input', (e) => {
      const query = e.target.value;
      if (!query) {
        results.innerHTML = '';
        return;
      }
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async () => {
        const search = await pagefind.search(query);
        const items = await Promise.all(search.results.slice(0, 10).map(r => r.data()));

        results.innerHTML = items.map(item => `
          <a href="${item.url}" class="block px-3 py-2.5 rounded-md hover:bg-[#111827] no-underline mb-1 transition-colors">
            <div class="text-sm text-[#e0e4ea] font-medium">${item.meta?.title || 'Untitled'}</div>
            <div class="text-xs text-[#6b7280] mt-0.5 line-clamp-2">${item.excerpt || ''}</div>
          </a>
        `).join('');
      }, 150);
    });
  }

  // Initialize Pagefind
  async function initPagefind() {
    const { results } = getSearchElements();
    if (!results) return;

    try {
      const pagefind = await import(pagefindModulePath);
      await pagefind.init();
      attachInputHandlers(pagefind);
    } catch (e) {
      if (window.location.hostname !== 'localhost') {
        results.innerHTML = '<div class="px-3 py-4 text-xs text-[#f87171]">Search index failed to load. Try refreshing.</div>';
      }
      console.warn('Pagefind not loaded:', e);
    }
  }

  initPagefind();
  document.addEventListener('astro:page-load', initPagefind);
</script>
