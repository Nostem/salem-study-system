---
interface Props {
  operatorName?: string;
  examDays?: number;
}

const { operatorName = 'operator', examDays = 42 } = Astro.props;

const now = new Date();
const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const dayName = dayNames[now.getDay()];
const timeOfDay = now.getHours() < 12 ? 'morning' : now.getHours() < 17 ? 'afternoon' : 'evening';
const dateStr = `${dayName} · ${monthNames[now.getMonth()]} ${now.getDate()}`;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<div class="w-full">
  <!-- Greeting row -->
  <div class="flex items-baseline justify-between mb-1">
    <div>
      <div class="font-mono text-[11px] tracking-[0.14em] text-text-muted uppercase">{dateStr}</div>
      <h1 class="font-serif text-[2.75rem] text-text-primary font-normal tracking-tight m-0 leading-tight">
        Good {timeOfDay}, {operatorName}.
      </h1>
    </div>
    <div class="text-right">
      <div class="font-mono text-[11px] tracking-[0.14em] text-text-muted uppercase">Exam in</div>
      <!-- TODO: wire to exam date config -->
      <div class="font-serif text-[2.75rem] text-status-draft leading-none">
        {examDays} <span class="text-sm text-text-muted">days</span>
      </div>
    </div>
  </div>

  <div class="h-px bg-border my-5"></div>

  <!-- Resume + Streak + Mastery row -->
  <div class="grid grid-cols-[2fr_1fr_1fr] gap-3.5">
    <!-- Resume card -->
    <!-- TODO: wire to last-read article from localStorage -->
    <div class="bg-bg-card border border-border rounded-md p-5" data-phase2>
      <div class="font-mono text-[10px] tracking-[0.14em] text-text-muted uppercase font-semibold">Resume</div>
      <div class="font-serif text-[1.625rem] text-text-primary mt-1.5">2022 NRC Written Exam — Q47</div>
      <div class="text-xs text-text-muted mt-1">Stopped 2 days ago · 46 of 75 answered · 72% so far</div>
      <!-- Progress bar: 75 segments -->
      <div class="flex gap-px mt-3">
        {Array.from({ length: 75 }).map((_, i) => (
          <div
            class:list={[
              "flex-1 h-1.5 rounded-sm",
              i < 33 ? "bg-mastery-ok" : i < 46 ? "bg-mastery-weak" : "bg-bg-surface"
            ]}
          />
        ))}
      </div>
      <div class="flex gap-2.5 mt-3.5">
        <a href={base} class="px-4 py-2 bg-status-draft text-bg font-semibold text-[13px] rounded no-underline" data-phase2>Resume exam &rsaquo;</a>
        <button class="px-4 py-2 bg-bg-card text-text-primary border border-border rounded text-[13px] cursor-pointer" data-phase2>Review wrong answers (13)</button>
      </div>
    </div>

    <!-- Streak card -->
    <!-- TODO: wire to study session tracking -->
    <div class="bg-bg-card border border-border rounded-md p-5" data-phase2>
      <div class="font-mono text-[10px] tracking-[0.14em] text-text-muted uppercase font-semibold">Streak</div>
      <div class="font-serif text-[2.5rem] text-status-draft leading-none mt-1">
        12 <span class="text-[13px] text-text-muted">days</span>
      </div>
      <div class="flex gap-1 mt-3">
        {['M','T','W','T','F','S','S'].map((d, i) => (
          <div class="flex-1 text-center">
            <div class:list={["h-6 rounded", i < 6 ? "bg-status-draft" : "bg-bg-surface"]} />
            <div class="text-[10px] text-text-muted mt-1">{d}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Overall mastery card -->
    <!-- TODO: wire to real mastery calculation -->
    <div class="bg-bg-card border border-border rounded-md p-5" data-phase2>
      <div class="font-mono text-[10px] tracking-[0.14em] text-text-muted uppercase font-semibold">Overall mastery</div>
      <div class="font-serif text-[2.5rem] text-text-primary leading-none mt-1">
        64<span class="text-sm text-text-muted">%</span>
      </div>
      <div class="text-[11.5px] text-text-muted mt-2 leading-relaxed">
        458 / 725 articles touched<br/>
        209 / 400 exam Qs correct
      </div>
    </div>
  </div>

  <!-- Today's queue + Weak areas row -->
  <div class="grid grid-cols-[1.4fr_1fr] gap-3.5 mt-3.5">
    <!-- Today's queue -->
    <!-- TODO: wire to spaced repetition / study queue -->
    <div class="bg-bg-card border border-border rounded-md p-5" data-phase2>
      <div class="flex justify-between items-baseline">
        <div class="font-serif text-[1.375rem] text-text-primary">Today's queue</div>
        <div class="text-[11px] text-text-muted">12 items · ~35 min</div>
      </div>
      <div class="mt-3">
        {[
          ['Q', 'Re-review: 2022 Q12 — Pressurizer LoLo trip setpoint', 'Missed last time', 'text-mastery-weak'],
          ['A', 'CVCS — boration flow path review', 'Due spaced', 'text-status-draft'],
          ['Q', 'Daily mixed quiz · 10 questions', 'New', 'text-mastery-ok'],
          ['T', 'TS 3/4.5 — ECCS surveillance bases', 'Not reviewed', 'text-text-muted'],
          ['J', 'JPM: Emergency Boration', 'Weak area', 'text-mastery-weak'],
        ].map(([kind, title, meta, color], i) => (
          <div class:list={["flex gap-3 py-2.5 items-center", i > 0 && "border-t border-bg-surface"]}>
            <div class:list={[
              "w-6 h-6 rounded grid place-items-center text-[11px] font-bold font-mono text-bg",
              kind === 'Q' && meta === 'Missed last time' ? 'bg-mastery-weak' :
              kind === 'A' ? 'bg-status-draft' :
              kind === 'Q' ? 'bg-mastery-ok' :
              kind === 'T' ? 'bg-text-muted' : 'bg-mastery-weak'
            ]}>{kind}</div>
            <div class="flex-1 text-[13.5px] text-text-body">{title}</div>
            <div class:list={["text-[11px] font-medium", color]}>{meta}</div>
            <div class="text-text-muted text-base">&rsaquo;</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Weak areas -->
    <!-- TODO: wire to real mastery per topic -->
    <div class="bg-bg-card border border-border rounded-md p-5" data-phase2>
      <div class="font-serif text-[1.375rem] text-text-primary mb-2.5">Weak areas</div>
      {[
        ['ECCS — recirculation phase', 38],
        ['SGTR diagnosis', 44],
        ['TS 3/4.3 bistable setpoints', 51],
        ['AFW discharge flow path', 56],
        ['EDG loading sequence', 60],
      ].map(([name, pct]) => (
        <div class="py-1.5">
          <div class="flex justify-between text-[12.5px]">
            <span class="text-text-body">{name}</span>
            <span class="font-mono text-mastery-weak font-semibold">{pct}%</span>
          </div>
          <div class="h-[3px] bg-bg-surface rounded mt-1">
            <div class="h-full bg-mastery-weak rounded" style={`width: ${pct}%`} />
          </div>
        </div>
      ))}
      <button class="mt-3.5 w-full py-2 px-2.5 bg-status-draft text-bg font-semibold text-xs rounded cursor-pointer border-none" data-phase2>
        Drill weak areas · 20 min &rsaquo;
      </button>
    </div>
  </div>
</div>
