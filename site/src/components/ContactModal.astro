---
---

<div id="contact-modal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="contact-modal-title" hidden>
  <div class="absolute inset-0 bg-black/60" data-contact-close></div>
  <div class="relative mx-auto mt-[10vh] w-[calc(100%-2rem)] max-w-lg bg-[#0d1220] border border-[#1a2035] rounded-lg shadow-2xl overflow-hidden">
    <div class="flex items-start justify-between gap-4 border-b border-[#1a2035] p-5">
      <div>
        <h2 id="contact-modal-title" class="text-[#e0e4ea] text-lg font-semibold m-0">Contact and feedback</h2>
        <p class="text-[#6b7280] text-sm mt-1 mb-0">Send a question, bug report, or content note. Page context is attached automatically.</p>
      </div>
      <button type="button" data-contact-close aria-label="Close contact form" class="text-[#6b7280] hover:text-[#e0e4ea] bg-transparent border-0 text-xl cursor-pointer">×</button>
    </div>

    <form id="contact-form" class="p-5 space-y-4">
      <label class="block">
        <span class="block text-[#6b7280] font-mono text-[11px] uppercase tracking-[0.12em] mb-1.5">Category</span>
        <select id="contact-category" name="category" class="w-full bg-[#111827] border border-[#1a2035] rounded-md px-3 py-2 text-sm text-[#e0e4ea] outline-none focus:border-[#2a6f97]">
          <option value="feedback">Feedback</option>
          <option value="bug">Bug</option>
          <option value="question">Question</option>
          <option value="content_issue">Content issue</option>
        </select>
      </label>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <label class="block">
          <span class="block text-[#6b7280] font-mono text-[11px] uppercase tracking-[0.12em] mb-1.5">Your name</span>
          <input id="contact-name" name="name" autocomplete="name" class="w-full bg-[#111827] border border-[#1a2035] rounded-md px-3 py-2 text-sm text-[#e0e4ea] outline-none focus:border-[#2a6f97]" />
        </label>
        <label class="block">
          <span class="block text-[#6b7280] font-mono text-[11px] uppercase tracking-[0.12em] mb-1.5">Reply email</span>
          <input id="contact-email" name="email" type="email" autocomplete="email" class="w-full bg-[#111827] border border-[#1a2035] rounded-md px-3 py-2 text-sm text-[#e0e4ea] outline-none focus:border-[#2a6f97]" />
        </label>
      </div>

      <label class="block">
        <span class="block text-[#6b7280] font-mono text-[11px] uppercase tracking-[0.12em] mb-1.5">Message</span>
        <textarea id="contact-message" name="message" rows="5" required minlength="10" maxlength="5000" class="w-full bg-[#111827] border border-[#1a2035] rounded-md px-3 py-2 text-sm text-[#e0e4ea] outline-none focus:border-[#2a6f97] resize-y" placeholder="What should be fixed, clarified, or added?"></textarea>
      </label>

      <label class="hidden" aria-hidden="true">
        Website
        <input id="contact-website" name="website" tabindex="-1" autocomplete="off" />
      </label>

      <div data-testid="contact-page-url" id="contact-page-url" class="text-[11px] text-[#6b7280] break-all"></div>
      <div data-testid="contact-status" id="contact-status" class="min-h-5 text-xs text-[#6b7280]" aria-live="polite"></div>

      <div class="flex justify-end gap-2 pt-1">
        <button type="button" data-contact-close class="px-3 py-2 text-xs font-mono text-[#6b7280] border border-[#1a2035] rounded-md bg-transparent hover:text-[#e0e4ea] cursor-pointer">Cancel</button>
        <button id="contact-submit" type="submit" class="px-3 py-2 text-xs font-mono text-[#e0e4ea] border border-[#2a6f97] rounded-md bg-[#123047] hover:bg-[#173a56] cursor-pointer">Send feedback</button>
      </div>
    </form>
  </div>
</div>

<div id="contact-confirmation" data-testid="contact-confirmation" class="fixed bottom-16 right-4 z-40 max-w-sm rounded-md border border-[#10b981]/40 bg-[#0d1220] px-4 py-3 text-xs text-[#10b981] shadow-lg hidden" aria-live="polite"></div>

<button
  id="contact-trigger"
  type="button"
  class="fixed bottom-4 right-4 z-40 rounded-full border border-[#2a6f97] bg-[#0d1220] px-4 py-2 text-xs font-mono text-[#c8cdd5] shadow-lg hover:bg-[#111827] hover:text-[#e0e4ea] transition-colors"
>
  Contact / Feedback
</button>

<script>
  import { submitContactFeedback } from '../utils/auth-client';

  function getContactElements() {
    return {
      modal: document.getElementById('contact-modal'),
      trigger: document.getElementById('contact-trigger'),
      form: document.getElementById('contact-form'),
      category: document.getElementById('contact-category'),
      name: document.getElementById('contact-name'),
      email: document.getElementById('contact-email'),
      message: document.getElementById('contact-message'),
      website: document.getElementById('contact-website'),
      pageUrl: document.getElementById('contact-page-url'),
      status: document.getElementById('contact-status'),
      confirmation: document.getElementById('contact-confirmation'),
      submit: document.getElementById('contact-submit'),
    };
  }

  function openContact() {
    const { modal, message, pageUrl, status, confirmation } = getContactElements();
    if (!modal) return;
    modal.hidden = false;
    modal.classList.remove('hidden');
    if (confirmation) {
      confirmation.textContent = '';
      confirmation.classList.add('hidden');
    }
    if (pageUrl) pageUrl.textContent = `Page: ${window.location.href}`;
    if (status) {
      status.textContent = '';
      status.className = 'min-h-5 text-xs text-[#6b7280]';
    }
    message?.focus();
  }

  function closeContact() {
    const { modal } = getContactElements();
    if (modal) {
      modal.classList.add('hidden');
      modal.hidden = true;
    }
  }

  function bindContactForm() {
    const { trigger, form } = getContactElements();
    if (trigger && trigger.dataset.contactBound !== 'true') {
      trigger.dataset.contactBound = 'true';
      trigger.addEventListener('click', openContact);
    }

    document.querySelectorAll('[data-contact-close]').forEach((button) => {
      if (button.dataset.contactBound === 'true') return;
      button.dataset.contactBound = 'true';
      button.addEventListener('click', closeContact);
    });

    if (!form || form.dataset.contactBound === 'true') return;
    form.dataset.contactBound = 'true';
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const { category, name, email, message, website, status, confirmation, submit } = getContactElements();
      if (!message || !status || !submit) return;

      submit.disabled = true;
      status.textContent = 'Sending feedback…';
      status.className = 'min-h-5 text-xs text-[#6b7280]';

      try {
        await submitContactFeedback({
          category: category?.value || 'feedback',
          name: name?.value || undefined,
          email: email?.value || undefined,
          message: message.value,
          pageUrl: window.location.href,
          userAgent: navigator.userAgent,
          website: website?.value || undefined,
        });
        form.reset();
        if (confirmation) {
          confirmation.textContent = 'Feedback sent. Thank you.';
          confirmation.classList.remove('hidden');
        }
        closeContact();
      } catch (error) {
        console.error('Failed to submit contact feedback', error);
        status.textContent = 'Feedback could not be sent. Please try again.';
        status.className = 'min-h-5 text-xs text-[#fbbf24]';
      } finally {
        submit.disabled = false;
      }
    });
  }

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeContact();
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindContactForm, { once: true });
  } else {
    bindContactForm();
  }
  document.addEventListener('astro:page-load', bindContactForm);
</script>
