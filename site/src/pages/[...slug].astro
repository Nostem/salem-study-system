---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('wiki');
  return articles
    .filter((a) => a.id !== '_index')
    .map((article) => {
      const slug = article.id;
      const category = slug.split('/')[0] ?? 'uncategorized';
      const title = article.data.title ?? slug.split('/').pop()?.replace(/-/g, ' ') ?? slug;
      return {
        params: { slug },
        props: { article, category, title },
      };
    });
}

const { article, category, title } = Astro.props;
const { Content, headings } = await render(article);
const status = article.data.status ?? 'draft';

// Check if this is an exam master article with child question articles
// e.g., exams/2023-written-exam has children in exams/2023/
const slug = article.id;
let embeddedQuestions: { Content: any; title: string; slug: string }[] = [];

if (slug.startsWith('exams/') && slug.includes('-written-exam')) {
  const yearMatch = slug.match(/exams\/(\d{4})-written-exam/);
  if (yearMatch) {
    const year = yearMatch[1];
    const allArticles = await getCollection('wiki');
    const questionArticles = allArticles
      .filter((a) => a.id.startsWith(`exams/${year}/q`))
      .sort((a, b) => {
        // Numeric sort: extract question number from filename (q1, q10, q100)
        const numA = parseInt(a.id.match(/\/q(\d+)/)?.[1] ?? '0');
        const numB = parseInt(b.id.match(/\/q(\d+)/)?.[1] ?? '0');
        return numA - numB;
      });

    for (const q of questionArticles) {
      const rendered = await render(q);
      const qTitle = q.data.title ?? q.id;
      embeddedQuestions.push({
        Content: rendered.Content,
        title: qTitle,
        slug: q.id,
      });
    }
  }
}

// Auto-embed JPMs and scenarios for operating exam master articles
if (slug.startsWith('exams/') && slug.includes('-operating-exam')) {
  const yearMatch = slug.match(/exams\/(\d{4})-operating-exam/);
  if (yearMatch) {
    const year = yearMatch[1];
    const allArticles = await getCollection('wiki');

    // Embed JPMs — sort: admin (ro, sro) → in-plant → sim
    const jpmTypeOrder: Record<string, number> = { 'ro': 0, 'sro': 1, 'ip': 2, 'sim': 3 };
    const jpmArticles = allArticles
      .filter((a) => a.id.startsWith(`exams/${year}/jpm-`))
      .sort((a, b) => {
        const typeA = a.id.match(/jpm-(ro|sro|ip|sim)/)?.[1] ?? '';
        const typeB = b.id.match(/jpm-(ro|sro|ip|sim)/)?.[1] ?? '';
        const orderA = jpmTypeOrder[typeA] ?? 99;
        const orderB = jpmTypeOrder[typeB] ?? 99;
        if (orderA !== orderB) return orderA - orderB;
        return a.id.localeCompare(b.id);
      });

    for (const jpm of jpmArticles) {
      const rendered = await render(jpm);
      const jpmTitle = jpm.data.title ?? jpm.id;
      embeddedQuestions.push({
        Content: rendered.Content,
        title: jpmTitle,
        slug: jpm.id,
      });
    }

    // Embed scenarios
    const scenarioArticles = allArticles
      .filter((a) => a.id.startsWith(`exams/scenarios/${year}-scenario-`))
      .sort((a, b) => a.id.localeCompare(b.id));

    for (const sc of scenarioArticles) {
      const rendered = await render(sc);
      const scTitle = sc.data.title ?? sc.id;
      embeddedQuestions.push({
        Content: rendered.Content,
        title: scTitle,
        slug: sc.id,
      });
    }
  }
}
---

<ArticleLayout
  title={title}
  category={category}
  status={status}
  slug={article.id}
  headings={headings}
>
  <Content />

  {embeddedQuestions.length > 0 && (
    <div class="embedded-questions" style="margin-top: 2rem;">
      {embeddedQuestions.map((q) => (
        <div class="embedded-question" data-slug={q.slug}>
          <q.Content />
        </div>
      ))}
    </div>
  )}
</ArticleLayout>
