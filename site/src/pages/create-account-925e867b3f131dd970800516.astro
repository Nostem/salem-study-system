---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<BaseLayout title="Create Account" noindex>
  <main class="min-h-screen bg-[#07111f] text-slate-100 px-6 py-12">
    <section class="mx-auto max-w-xl rounded-2xl border border-slate-700/80 bg-slate-900/80 p-8 shadow-2xl">
      <p class="mb-2 font-mono text-xs uppercase tracking-[0.22em] text-amber-300">Private beta access</p>
      <h1 class="mb-3 text-3xl font-semibold text-white">Create your Salem Study account</h1>
      <p class="mb-8 text-sm leading-6 text-slate-300">
        Create a username and password for the Salem Study beta. No email is required. A unique learner ID will be created automatically and stored on the backend.
      </p>

      <div id="configWarning" class="mb-5 hidden rounded-lg border border-amber-400/40 bg-amber-400/10 p-3 text-sm text-amber-100">
        Supabase public config is not set for this build yet. The form is ready, but account creation calls need deployment env vars.
      </div>

      <form id="createAccountForm" data-login-url={`${base}login`} class="space-y-5">
        <label class="block text-sm font-medium text-slate-200">
          Username
          <input name="username" autocomplete="username" minlength="3" maxlength="32" pattern="[A-Za-z0-9_][A-Za-z0-9_-]{2,31}" required class="mt-2 w-full rounded-lg border border-slate-600 bg-slate-950 px-4 py-3 text-white outline-none focus:border-amber-300" placeholder="operator_one" />
          <span class="mt-1 block text-xs text-slate-400">3–32 characters. Letters, numbers, underscore, and hyphen.</span>
        </label>

        <label class="block text-sm font-medium text-slate-200">
          Password
          <input name="password" type="password" autocomplete="new-password" minlength="8" required class="mt-2 w-full rounded-lg border border-slate-600 bg-slate-950 px-4 py-3 text-white outline-none focus:border-amber-300" placeholder="Minimum 8 characters" />
        </label>

        <label class="block text-sm font-medium text-slate-200">
          Display name <span class="text-slate-500">optional</span>
          <input name="displayName" autocomplete="name" class="mt-2 w-full rounded-lg border border-slate-600 bg-slate-950 px-4 py-3 text-white outline-none focus:border-amber-300" placeholder="How you want to appear" />
        </label>

        <button class="w-full rounded-lg bg-amber-300 px-4 py-3 font-semibold text-slate-950 transition hover:bg-amber-200" type="submit">
          Create account
        </button>
      </form>

      <p id="createAccountStatus" class="mt-5 min-h-6 text-sm text-slate-300" role="status"></p>

      <p class="mt-8 border-t border-slate-700 pt-5 text-sm text-slate-400">
        Already have an account? <a class="text-amber-300 hover:text-amber-200" href={`${base}login`}>Log in with username</a>.
      </p>
    </section>
  </main>

  <script>
    import { hasSupabaseConfig, signupWithInvite } from '../utils/auth-client';

    const form = document.querySelector<HTMLFormElement>('#createAccountForm');
    const status = document.querySelector<HTMLElement>('#createAccountStatus');
    const warning = document.querySelector<HTMLElement>('#configWarning');

    if (!hasSupabaseConfig()) {
      warning?.classList.remove('hidden');
    }

    const messages: Record<string, string> = {
      username_taken: 'That username is already taken.',
      invalid_username: 'Use 3–32 characters: letters, numbers, underscore, or hyphen.',
      password_too_short: 'Password must be at least 8 characters.',
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!status) return;

      const data = new FormData(form);
      const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      submit?.setAttribute('disabled', 'true');
      status.textContent = 'Creating account…';
      status.className = 'mt-5 min-h-6 text-sm text-slate-300';

      try {
        await signupWithInvite({
          username: String(data.get('username') ?? ''),
          password: String(data.get('password') ?? ''),
          displayName: String(data.get('displayName') ?? ''),
        });
        status.textContent = 'Account created. Redirecting to login…';
        status.className = 'mt-5 min-h-6 text-sm text-emerald-300';
        window.location.href = form.getAttribute('data-login-url') || 'login';
      } catch (error) {
        const key = error instanceof Error ? error.message : 'request_failed';
        status.textContent = messages[key] ?? 'Account creation failed. Try again or contact the site administrator.';
        status.className = 'mt-5 min-h-6 text-sm text-red-300';
      } finally {
        submit?.removeAttribute('disabled');
      }
    });
  </script>
</BaseLayout>
