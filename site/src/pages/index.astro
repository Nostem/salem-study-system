// Exam years with data
const examYears = [
  { year: '2023', written: true, operating: true, qCount: examCounts['2023'] || 0, jpmCount: 20, scenarioCount: 4, ilot: '19-01' },
  { year: '2022', written: true, operating: true, qCount: examCounts['2022'] || 0, jpmCount: 20, scenarioCount: 3, ilot: '20-01' },
  { year: '2020', written: true, operating: true, qCount: examCounts['2020'] || 0, jpmCount: 20, scenarioCount: 5, ilot: '18-01' },
  { year: '2019', written: true, operating: true, qCount: examCounts['2019'] || 0, jpmCount: 20, scenarioCount: 3, ilot: '17-01' },
  { year: '2018', written: true, operating: true, qCount: examCounts['2018'] || 0, jpmCount: 20, scenarioCount: 2, ilot: '16-01' },
];

