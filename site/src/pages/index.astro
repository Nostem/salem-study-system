---

<BaseLayout title="Salem Study Wiki">
  <SearchModal />
  <div class="max-w-[1100px] mx-auto px-8 py-10">

    <!-- HEADER -->
    <div class="flex items-end justify-between mb-8 pb-6 border-b border-border">
      <div>
        <h1 class="font-mono text-[13px] font-medium tracking-[0.18em] text-text-primary m-0">SALEM STUDY WIKI</h1>
        <p class="text-text-muted text-sm mt-1 m-0">{totalArticles} articles · {examYears.length} exams · {counts['systems'] || 0} systems</p>
      </div>
      <div class="flex-1 max-w-[360px] mx-6">
        <button
          id="home-search-trigger"
          class="w-full flex items-center gap-2.5 bg-bg-card border border-border rounded-md px-4 py-2.5 text-left cursor-pointer hover:border-border-hi transition-colors"
        >
          <span class="text-text-muted text-xs">&#8984;K</span>
          <span class="text-text-muted text-sm">Search articles...</span>
        </button>
      </div>
      <div class="flex gap-2">
        <a href={`${base}graph`} class="px-3 py-1.5 text-[11px] font-mono text-text-muted border border-border rounded hover:border-accent-blue hover:text-accent-blue no-underline transition-colors">Graph View</a>
        <a href={`${base}quiz`} class="px-3 py-1.5 text-[11px] font-mono text-text-muted border border-border rounded hover:border-accent-blue hover:text-accent-blue no-underline transition-colors">Quiz Builder</a>
        <a href={`${base}plant`} class="px-3 py-1.5 text-[11px] font-mono text-text-muted border border-border rounded hover:border-accent-blue hover:text-accent-blue no-underline transition-colors">Plant Overview</a>
      </div>
    </div>

    <!-- NAVIGATION CARDS -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-10">
      {navCards.map(card => (
        <a href={card.href} class="bg-bg-card border border-border rounded-md p-4 no-underline hover:border-border-hi transition-colors group">
          <div class="flex items-center gap-2 mb-2">
            <span style={`color: ${card.color}`} class="text-lg">{card.glyph}</span>
            <span class="text-text-primary text-sm font-medium group-hover:text-accent-blue transition-colors">{card.name}</span>
          </div>
          <div class="font-mono text-text-muted text-xs">{card.count} articles</div>
        </a>
      ))}
    </div>

    <!-- SOURCE DOCUMENTS -->
    <h2 class="font-mono text-[11px] font-semibold tracking-[0.14em] text-text-muted uppercase mb-4">Source Documents</h2>

    <!-- UFSAR + Tech Specs row -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 mb-6">
      <!-- UFSAR -->
      <div class="bg-bg-card border border-border rounded-md p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-accent-blue text-sm">&#9638;</span>
          <span class="text-text-primary text-sm font-semibold">UFSAR (by Chapter)</span>
        </div>
        <div class="grid grid-cols-2 gap-x-6 gap-y-0.5">
          <div>
            {[
              ['ufsar-chapter-01', 'Ch 1 — Introduction'],
              ['ufsar-chapter-02', 'Ch 2 — Site Characteristics'],
              ['ufsar-chapter-03', 'Ch 3 — Design Criteria'],
              ['ufsar-chapter-04', 'Ch 4 — Reactor'],
              ['ufsar-chapter-05', 'Ch 5 — RCS'],
              ['ufsar-chapter-06', 'Ch 6 — ESF'],
              ['ufsar-chapter-07', 'Ch 7 — I&C'],
              ['ufsar-chapter-08', 'Ch 8 — Electrical'],
              ['ufsar-chapter-09', 'Ch 9 — Auxiliary Systems'],
            ].map(([slug, label]) => (
              <a href={`${base}ts-pdfs/${slug}.pdf`} target="_blank" class="block text-accent-blue text-[11px] no-underline hover:underline py-0.5 leading-tight">{label}</a>
            ))}
          </div>
          <div>
            {[
              ['ufsar-chapter-10', 'Ch 10 — Steam & Power'],
              ['ufsar-chapter-11', 'Ch 11 — Rad Waste'],
              ['ufsar-chapter-12', 'Ch 12 — Radiation Protection'],
              ['ufsar-chapter-13', 'Ch 13 — Conduct of Ops'],
              ['ufsar-chapter-14', 'Ch 14 — Initial Tests'],
              ['ufsar-chapter-15', 'Ch 15 — Accident Analysis'],
              ['ufsar-chapter-16', 'Ch 16 — Tech Specs'],
              ['ufsar-chapter-17', 'Ch 17 — QA'],
            ].map(([slug, label]) => (
              <a href={`${base}ts-pdfs/${slug}.pdf`} target="_blank" class="block text-accent-blue text-[11px] no-underline hover:underline py-0.5 leading-tight">{label}</a>
            ))}
          </div>
        </div>
      </div>

      <!-- Tech Specs & Bases -->
      <div class="bg-bg-card border border-border rounded-md p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-accent-green text-sm">&#9638;</span>
          <span class="text-text-primary text-sm font-semibold">Tech Specs & Bases</span>
        </div>
        <div class="grid grid-cols-2 gap-x-6 gap-y-0.5">
          <div>
            <div class="font-mono text-[9px] text-text-muted uppercase tracking-wider mb-1">Tech Specs</div>
            {tsPdfs.map(slug => (
              <a href={`${base}ts-pdfs/${slug}.pdf`} target="_blank" class="block text-accent-blue text-[11px] no-underline hover:underline py-0.5 leading-tight">
                {tsLabels[slug] || slug}
              </a>
            ))}
          </div>
          <div>
            <div class="font-mono text-[9px] text-text-muted uppercase tracking-wider mb-1">Bases</div>
            {basesPdfs.map(slug => (
              <a href={`${base}ts-pdfs/${slug}.pdf`} target="_blank" class="block text-accent-blue text-[11px] no-underline hover:underline py-0.5 leading-tight">
                {basesLabels[slug] || slug}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- EXAM YEAR CARDS -->
    <h2 class="font-mono text-[11px] font-semibold tracking-[0.14em] text-text-muted uppercase mb-4">NRC Exams</h2>

    <div class="flex flex-col gap-3">
      {examYears.map(exam => (
        <div class="bg-bg-card border border-border rounded-md p-5">
          <div class="flex items-start gap-5">
            <!-- Year -->
            <div class="font-serif text-[2.5rem] text-text-primary leading-none min-w-[80px]">{exam.year}</div>

            <!-- Content -->
            <div class="flex-1">
              <div class="text-text-muted text-[10px] font-mono uppercase tracking-wider mb-2">ILOT {exam.ilot}</div>

              <div class="grid grid-cols-2 gap-4">
                <!-- Written -->
                <div>
                  <div class="text-text-primary text-sm font-medium mb-1">Written Exam</div>
                  <a href={`${base}exam-pdfs/${exam.year}-written.pdf`} target="_blank" class="text-accent-blue text-xs no-underline hover:underline">View PDF</a>
                  <span class="text-text-muted text-xs ml-2">{exam.qCount > 0 ? `${exam.qCount} questions ingested` : 'not yet ingested'}</span>
                  {exam.qCount > 0 && (
                    <a href={`${base}exams/${exam.year}-written-exam`} class="block text-accent-teal text-[11px] no-underline hover:underline mt-1">Browse questions &rsaquo;</a>
                  )}
                </div>

                <!-- Operating -->
                <div>
                  <div class="text-text-primary text-sm font-medium mb-1">Operating Exam</div>
                  <a href={`${base}exam-pdfs/${exam.year}-operating.pdf`} target="_blank" class="text-accent-blue text-xs no-underline hover:underline">View PDF</a>
                  <span class="text-text-muted text-xs ml-2">{exam.jpmCount} JPMs · {exam.scenarioCount} scenarios</span>
                  <a href={`${base}exams/${exam.year}-operating-exam`} class="block text-accent-teal text-[11px] no-underline hover:underline mt-1">Browse JPMs &rsaquo;</a>
                </div>
              </div>

              <!-- Expandable JPMs & Scenarios -->
              <details class="mt-3">
                <summary class="cursor-pointer text-text-muted text-[11px] font-mono hover:text-text-body transition-colors">
                  View all JPMs & Scenarios ({exam.jpmCount + exam.scenarioCount} PDFs)
                </summary>
                <div class="mt-2 grid grid-cols-4 gap-x-4 gap-y-0.5 text-[10px]">
                  {['RO Admin', 'SRO Admin', 'Simulator', 'In-Plant'].map(type => {
                    const items = (jpmSlugs[exam.year] || []).filter(j => j.type === type);
                    return items.length > 0 ? (
                      <div>
                        <div class="font-mono text-text-muted uppercase tracking-wider mb-0.5">{type}</div>
                        {items.map(j => (
                          <a href={`${base}exam-pdfs/${j.slug}.pdf`} target="_blank" class="block text-accent-blue no-underline hover:underline py-px">{j.label}</a>
                        ))}
                      </div>
                    ) : null;
                  })}
                  <div>
                    <div class="font-mono text-text-muted uppercase tracking-wider mb-0.5">Scenarios</div>
                    {(scenarioSlugs[exam.year] || []).map((s, i) => (
                      <a href={`${base}exam-pdfs/${s}.pdf`} target="_blank" class="block text-accent-blue no-underline hover:underline py-px">Scenario {i + 1}</a>
                    ))}
                  </div>
                </div>
              </details>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('home-search-trigger')?.addEventListener('click', () => {
        if (typeof window.openSearch === 'function') window.openSearch();
      });
    });
  </script>
</BaseLayout>
