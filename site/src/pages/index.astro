---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchModal from '../components/SearchModal.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

// Real article counts from collection
const articles = await getCollection('wiki');
const counts: Record<string, number> = {};
for (const a of articles) {
  const cat = a.id.split('/')[0] ?? 'uncategorized';
  if (cat === '_index') continue;
  counts[cat] = (counts[cat] || 0) + 1;
}

// Count ingested exam questions per year
const examCounts: Record<string, number> = {};
for (const a of articles) {
  const parts = a.id.split('/');
  if (parts[0] === 'exams' && parts.length === 3 && parts[2]?.startsWith('q')) {
    const year = parts[1];
    examCounts[year] = (examCounts[year] || 0) + 1;
  }
}

const totalArticles = articles.filter(a => a.id !== '_index').length;

const navCards = [
  { name: 'Systems', count: counts['systems'] || 0, color: '#60a5fa', glyph: '◈', href: `${base}systems/reactor-coolant-system` },
  { name: 'Tech Specs', count: counts['tech-specs'] || 0, color: '#10b981', glyph: '◇', href: `${base}tech-specs/ts-1-0-definitions` },
  { name: 'NRC Exams', count: counts['exams'] || 0, color: '#f59e0b', glyph: '◉', href: `${base}exams/2023-written-exam` },
  { name: 'EOPs', count: counts['eops'] || 0, color: '#ef4444', glyph: '△', href: `${base}eops/eop-trip-1-reactor-trip-or-si` },
  { name: 'Abnormals', count: counts['abnormals'] || 0, color: '#6b7280', glyph: '⬡', href: `${base}abnormals/ab-loca-0001-shutdown-loca` },
  { name: 'Procedures', count: counts['procedures'] || 0, color: '#60a5fa', glyph: '▤', href: `${base}procedures/s2-op-so-rm-0001-radiation-monitoring-system-operation` },
  { name: 'Admin', count: counts['admin'] || 0, color: '#2a6f97', glyph: '▣', href: `${base}admin/op-aa-101-111-roles-and-responsibilities` },
  { name: 'Concepts', count: counts['concepts'] || 0, color: '#a78bfa', glyph: '✦', href: `${base}` },
];

// Tech Spec PDFs grouped
const tsPdfs = [
  'ts-1-0', 'ts-2-0', 'ts-3-4-1-1', 'ts-3-4-1-2', 'ts-3-4-1-3', 'ts-3-4-2',
  'ts-3-4-3', 'ts-3-4-4-1', 'ts-3-4-4-2', 'ts-3-4-4-3', 'ts-3-4-4-4', 'ts-3-4-4-5',
  'ts-3-4-4-6', 'ts-3-4-4-7', 'ts-3-4-4-9', 'ts-3-4-5', 'ts-3-4-6-1', 'ts-3-4-6-2',
  'ts-3-4-6-3', 'ts-3-4-7-1', 'ts-3-4-7-2', 'ts-3-4-7-3', 'ts-3-4-7-4', 'ts-3-4-7-5',
  'ts-3-4-7-6', 'ts-3-4-7-7', 'ts-3-4-8-1', 'ts-3-4-8-2', 'ts-3-4-8-3', 'ts-3-4-9',
  'ts-3-4-10', 'ts-3-4-11',
];
const tsLabels: Record<string, string> = {
  'ts-1-0': 'TS 1.0 Definitions', 'ts-2-0': 'TS 2.0 Safety Limits',
  'ts-3-4-1-1': 'TS 3/4.1.1 Boration', 'ts-3-4-1-2': 'TS 3/4.1.2 Boration Systems',
  'ts-3-4-1-3': 'TS 3/4.1.3 Movable Control', 'ts-3-4-2': 'TS 3/4.2 Power Distribution',
