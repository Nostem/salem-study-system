  'bases-3-4-3': 'Bases 3/4.3', 'bases-3-4-4': 'Bases 3/4.4', 'bases-3-4-5': 'Bases 3/4.5',
  'bases-3-4-6': 'Bases 3/4.6', 'bases-3-4-7': 'Bases 3/4.7', 'bases-3-4-8': 'Bases 3/4.8',
  'bases-3-4-9': 'Bases 3/4.9', 'bases-3-4-10': 'Bases 3/4.10', 'bases-3-4-11': 'Bases 3/4.11',
